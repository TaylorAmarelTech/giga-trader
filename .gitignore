# ═══════════════════════════════════════════════════════════════════════════════
# GIGA TRADER - Git Ignore
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
package-lock.json
pnpm-lock.yaml

# ─────────────────────────────────────────────────────────────────────────────────
# Environment & Secrets
# ─────────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
credentials/
secrets/
*.pem
*.key
*.p12

# ─────────────────────────────────────────────────────────────────────────────────
# Data (Large files - store in cloud/DVC)
# ─────────────────────────────────────────────────────────────────────────────────
data/raw/*.db
data/raw/*.csv
data/raw/*.parquet
data/processed/*.db
data/processed/*.csv
data/processed/*.parquet
data/synthetic/*.db
data/synthetic/*.csv
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────────────────────────
# Models (Large files - store in cloud/MLflow)
# ─────────────────────────────────────────────────────────────────────────────────
models/checkpoints/*.pkl
models/production/*.pkl
models/*.joblib
models/*.h5
models/*.onnx
!models/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────────
# Logs & Reports
# ─────────────────────────────────────────────────────────────────────────────────
logs/*.log
logs/*.json
reports/*.html
reports/*.pdf
!logs/.gitkeep
!reports/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────────
# IDE & Editors
# ─────────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-*
.spyderproject
.spyproject

# ─────────────────────────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─────────────────────────────────────────────────────────────────────────────────
# Build & Distribution
# ─────────────────────────────────────────────────────────────────────────────────
dist/
build/
*.whl

# ─────────────────────────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─────────────────────────────────────────────────────────────────────────────────
# Claude Code Harness
# ─────────────────────────────────────────────────────────────────────────────────
claude-code-harness.config.local.json

# ─────────────────────────────────────────────────────────────────────────────────
# Temporary Files
# ─────────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*~
nul

# ─────────────────────────────────────────────────────────────────────────────────
# Claude Code Workspace
# ─────────────────────────────────────────────────────────────────────────────────
.claude/

# ─────────────────────────────────────────────────────────────────────────────────
# Experiments (runtime state)
# ─────────────────────────────────────────────────────────────────────────────────
experiments/*.json
!experiments/.gitkeep

# ─────────────────────────────────────────────────────────────────────────────────
# Cache
# ─────────────────────────────────────────────────────────────────────────────────
data/cache/
*.parquet

{
  "$schema": "https://raw.githubusercontent.com/Chachamaru127/claude-code-harness/main/claude-code-harness.config.schema.json",
  "version": "1.0",

  "i18n": {
    "language": "en"
  },

  "constitution": {
    "path": "docs/constitution.md"
  },

  "work": {
    "auto_commit": false,
    "commit_on_pm_approve": false
  },

  "safety": {
    "mode": "standard",
    "require_confirmation": true,
    "max_auto_retries": 3
  },

  "git": {
    "allow_auto_commit": false,
    "allow_auto_push": false,
    "protected_branches": ["main", "master", "production"],
    "commit_prefix": "feat:"
  },

  "paths": {
    "allowed_modify": [
      "src/",
      "app/",
      "components/",
      "lib/",
      "pages/",
      "Plans.md",
      "AGENTS.md",
      "CLAUDE.md"
    ],
    "protected": [
      ".github/",
      ".env",
      ".env.*",
      "credentials/",
      "secrets/"
    ],
    "plans_file": "Plans.md",
    "agents_file": "AGENTS.md"
  },

  "ci": {
    "provider": "auto",
    "enable_auto_fix": false,
    "require_gh_cli": true
  },

  "scaffolding": {
    "tech_choice_mode": "ask",
    "allow_web_search": true
  },

  "destructive_commands": {
    "allow_rm_rf": false,
    "allow_npm_install": true,
    "require_size_check": true,
    "max_files_to_modify": 20
  }
}

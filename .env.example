# ═══════════════════════════════════════════════════════════════════════════════
# GIGA TRADER - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# DATA SOURCES - Market Data APIs
# ─────────────────────────────────────────────────────────────────────────────────

# Alpaca (Primary data source for equities)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Yahoo Finance (Backup/historical data)
# No API key needed for yfinance, but rate limiting applies

# Polygon.io (Alternative data source)
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage (Fundamental data)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_api_key_here

# ─────────────────────────────────────────────────────────────────────────────────
# TRADING CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# Trading Mode: paper | live
TRADING_MODE=paper

# Initial Capital
INITIAL_CAPITAL=100000

# Risk Parameters
MAX_POSITION_SIZE_PCT=25
MAX_DAILY_LOSS_PCT=2
MAX_DRAWDOWN_PCT=10
CONSECUTIVE_LOSS_LIMIT=5

# ─────────────────────────────────────────────────────────────────────────────────
# MODEL & PIPELINE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_PATH=data/giga_trader.db

# Model Storage
MODELS_DIR=models
CHECKPOINTS_DIR=models/checkpoints

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# ─────────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS (Optional)
# ─────────────────────────────────────────────────────────────────────────────────

# Discord Webhook (for alerts)
DISCORD_WEBHOOK_URL=

# Telegram Bot (for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (for daily reports)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# ─────────────────────────────────────────────────────────────────────────────────
# EXTERNAL SERVICES (Optional)
# ─────────────────────────────────────────────────────────────────────────────────

# OpenAI/Claude (for autonomous discovery)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# News Sentiment APIs
NEWS_API_KEY=
BENZINGA_API_KEY=
